YOUTUBE_API_KEY=
LASTFM_API_KEY=
AURALIZE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional regex fallback, e.g. ^https://.*\.vercel\.app$
AURALIZE_CORS_ORIGIN_REGEX=
# Optional upload override (bytes), default is 52428800 (50 MB)
AURALIZE_MAX_UPLOAD_BYTES=52428800
# Optional safety ceiling after gzip decompression (bytes), default is 209715200 (200 MB)
AURALIZE_MAX_DECOMPRESSED_UPLOAD_BYTES=209715200
